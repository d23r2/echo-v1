# Copy to .env and fill in what you have. Missing keys just disable that provider
# (it will show as unavailable in the UI instead of crashing the app).

# CORS: comma-separated origins allowed to call this API.
# For remote access (e.g. Tailscale), add your machine's Tailscale IP for
# whichever port serves the frontend, e.g. http://100.x.x.x:5174 (dev server)
# and/or http://100.x.x.x:3000 (docker compose / nginx build).
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,http://localhost:3000

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# OpenAI (GPT)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# xAI (Grok) — OpenAI-compatible endpoint
XAI_API_KEY=
XAI_MODEL=grok-4

# Google (Gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Ollama (local fallback, no key needed — just needs to be running)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

DEFAULT_PROVIDER=auto

# Echo persona tuning
INDEPENDENCE_NUDGE_EVERY_N_TURNS=6
ATLAS_TOP_K=5
