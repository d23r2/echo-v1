# Copy to .env and fill in what you have. Missing keys just disable that provider
# (it will show as unavailable in the UI instead of crashing the app).

# CORS: comma-separated origins allowed to call this API.
# For remote access (e.g. Tailscale), add your machine's Tailscale IP for
# whichever port serves the frontend, e.g. http://100.x.x.x:5174 (dev server)
# and/or http://100.x.x.x:3000 (docker compose / nginx build).
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,http://localhost:3000

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# OpenAI (GPT)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# xAI (Grok) — OpenAI-compatible endpoint
XAI_API_KEY=
XAI_MODEL=grok-4

# Google (Gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Ollama (local fallback, no key needed — just needs to be running)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

DEFAULT_PROVIDER=auto

# Echo persona tuning
INDEPENDENCE_NUDGE_EVERY_N_TURNS=6
ATLAS_TOP_K=5

# --- Provider fallback / free-mode tuning ---

# Whether "auto" mode falls back to local Ollama when every cloud provider is
# unavailable/quota-limited. true is the safe default — set false only if you
# specifically don't want Ollama used as a silent fallback.
OLLAMA_ALWAYS_AVAILABLE_FALLBACK=true

# Minutes a provider is skipped after a quota/credit/billing/rate-limit error,
# so auto mode stops re-trying a call it already knows will fail. 0 disables
# cooldown tracking entirely.
PROVIDER_COOLDOWN_MINUTES=30

# When true: "auto" mode prefers Ollama, treats Gemini's free tier as an
# optional helper, and never reaches Anthropic/OpenAI/Grok/Azure even if
# their keys are configured (pin to one of them by name to bypass this).
# Good default for running Echo at zero/near-zero cost.
FREE_MODE=false

# --- Azure OpenAI (disabled by default; never primary in FREE_MODE) ---
AZURE_OPENAI_ENABLED=false
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21
# Optional self-imposed daily caps (leave blank to skip the check entirely —
# this is separate from whatever limits Azure's own billing enforces).
AZURE_DAILY_REQUEST_LIMIT=
AZURE_DAILY_TOKEN_LIMIT=

# --- Image generation provider selection ---
# auto (Gemini/Imagen if configured, else clean "unavailable") | gemini |
# ollama (never actually generates in this build) | comfyui (reachability
# check only — see app/image_router.py) | disabled
IMAGE_PROVIDER=auto
COMFYUI_BASE_URL=

# Reserved for a future free-tier provider integration — not yet wired to an
# actual provider in this build, setting these currently has no effect.
OPENROUTER_API_KEY=
GROQ_API_KEY=

# --- No-billing web/wiki/RSS search (see docs/searxng-setup.md) ---
# All of this is genuinely free — no API key, no billing account, anywhere.
# Echo works fully with all of it left at defaults; it just can't answer
# current/live questions (and says so honestly) without SearXNG or RSS
# configured. Wiki is on by default since Wikimedia's public search API
# needs no setup at all.

# Web search — requires a SearXNG instance (self-hosted or a public one you
# trust). Off by default. See docker-compose.searxng.yml for a one-command
# local instance.
WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=searxng
SEARXNG_BASE_URL=http://localhost:8080
WEB_SEARCH_MAX_RESULTS=5
WEB_FETCH_TIMEOUT_SECONDS=10
WEB_SEARCH_CACHE_MINUTES=10

# Wikipedia/Wikimedia search — public API, no key, on by default. Good for
# stable background/definitional/historical facts; never used as proof of
# anything current/live (see backend/app/persona.py's SOURCE_USAGE_INSTRUCTION).
WIKI_SEARCH_ENABLED=true
WIKI_PROVIDER=wikimedia
WIKI_API_BASE_URL=https://en.wikipedia.org/w/api.php
WIKI_MAX_RESULTS=5
WIKI_FETCH_TIMEOUT_SECONDS=10
# Sent as the User-Agent header on every Wiki/SearXNG/RSS/direct-page request.
# Wikimedia rejects requests whose User-Agent doesn't look like it has a URL
# in it (its robot policy) — the default below already complies, so you only
# need to change this to identify your own instance distinctly. Not a
# credential — just client identification, safe to leave as-is.
WIKI_USER_AGENT=EchoPersonalAI/1.0 (https://github.com/echo-project/echo; local self-hosted, no-billing search) python-httpx

# RSS/Atom feeds — for news/sports headlines. Off by default (no feeds
# configured). Comma-separated list of feed URLs.
RSS_SEARCH_ENABLED=false
RSS_FEED_URLS=
RSS_MAX_ITEMS_PER_FEED=10
RSS_FETCH_TIMEOUT_SECONDS=10
RSS_CACHE_MINUTES=10
